# Auto detect text files and perform LF normalization
* text=auto

# Python
*.py text diff=python
*.pyx text diff=python

# Docs
*.md text diff=markdown
*.txt text

# Docker
Dockerfile text
docker-compose.yml text

# Shell
*.sh text eol=lf

# Windows
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary
*.png binary
*.jpg binary
*.ico binary
*.pkl binary
*.bin binary
*.pt binary
*.onnx binary

# Large files (if using Git LFS later)
# *.bin filter=lfs diff=lfs merge=lfs -text
